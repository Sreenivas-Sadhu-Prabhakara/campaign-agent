# ============================================================
#  Lead Campaign App — environment variables
#  Copy this file to ".env" and fill in real values.
# ============================================================

# ---- Core ----
# SQLite for local dev. For production use Postgres, e.g.
#   DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DATABASE_URL="file:./dev.db"

# Public URL of your app (used in email links + tracking). No trailing slash.
APP_URL="http://localhost:3000"

# Admin dashboard key  ->  visit /dashboard?key=THIS
ADMIN_KEY="change-me-to-something-secret"

# Protects the cron drip endpoint. Vercel Cron sends it automatically.
CRON_SECRET="change-me-too"

# Shown in email footers (legally required) + used in copy.
COMPANY_NAME="Your Company"
COMPANY_ADDRESS="123 Example Street, Your City, 00000"

# Where the welcome/offer CTA points (your lead magnet, booking page, etc.)
OFFER_URL="https://your-site.com/guide"

# ---- Email (Resend) ----
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# Must be a verified domain in Resend, e.g. "Sam <hello@yourdomain.com>"
EMAIL_FROM="Your Name <hello@yourdomain.com>"

# ============================================================
#  META  (Facebook / Instagram Lead Ads + WhatsApp + Messenger)
#  All four share ONE Meta app + ONE webhook (/api/webhooks/meta).
# ============================================================

# Graph API version
GRAPH_VERSION="v21.0"

# You invent this string; you also paste it into the Meta webhook config.
META_VERIFY_TOKEN="pick-any-random-string"

# App secret (Meta App > Settings > Basic). Used to verify webhook signatures.
META_APP_SECRET=""

# Page access token (for Lead Ads retrieval + Messenger/Instagram replies).
META_PAGE_ACCESS_TOKEN=""

# ---- WhatsApp Cloud API ----
# From Meta > WhatsApp > API Setup.
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
# Names of your PRE-APPROVED WhatsApp message templates (one per drip step).
# Each should have a single body parameter {{1}} = the lead's name.
WHATSAPP_TEMPLATE_WELCOME="lead_welcome"
WHATSAPP_TEMPLATE_VALUE="lead_value"
WHATSAPP_TEMPLATE_OFFER="lead_offer"
WHATSAPP_TEMPLATE_LANG="en"
